# Port this service listens on.
PORT=3020

# Where this service stores chat conversations (SQLite).
DATABASE_PATH=./data/widget.db

# Base URL of the Voice Agents dashboard this service integrates with.
DASHBOARD_URL=http://localhost:3000

# Shared service-to-service secret. Generate it in the dashboard's global
# Admin Settings → Chat Widget Service, and paste the same value here.
WIDGET_SERVICE_SECRET=

# Optional: 64 hex chars (32 bytes) to encrypt stored conversations at rest.
# If unset, a local key file is generated next to the database (see README).
# ENCRYPTION_KEY=
